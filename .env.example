# shouldigetgas — environment variables
# Copy to .env and fill in real values before running the backend.

# ── Required for US price data ─────────────────────────────────────────────────
# Register free at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ── Required for news headlines (optional but recommended) ────────────────────
# Register free at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── GNews fallback (optional — used as secondary news source if NewsAPI is absent) ──
# Register free at: https://gnews.io/
# GNEWS_API_KEY=your_gnews_key_here

# ── Required for LLM news analysis (optional — heuristic fallback if absent) ──
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Redis cache (optional — in-memory fallback used if Redis is unreachable) ──
REDIS_URL=redis://localhost:6379/0

# ── GasBuddy (optional) ───────────────────────────────────────────────────────
# GasBuddy is behind Cloudflare. From a residential host it's usually reachable
# with no extra config. From a datacenter IP, point this at a FlareSolverr-
# compatible endpoint to clear the challenge when fetching the CSRF token.
# GASBUDDY_SOLVER_URL=http://localhost:8191/v1
# Token cache location (default: <DB dir>/gasbuddy_token).
# GASBUDDY_TOKEN_CACHE=data/gasbuddy_token

# ── Paths (defaults shown; override if needed) ────────────────────────────────
# DB_PATH=data/shouldigetgas.db
# DATA_JSON_PATH=frontend/data/data.json

# ── Refresh intervals ─────────────────────────────────────────────────────────
# PRICE_REFRESH_MINUTES=30
# ANALYTICS_REFRESH_HOURS=6
